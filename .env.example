# Copy to .env.local and fill in. See README.md for the full setup.

# Convex deployment URL.
# Written automatically by `npx convex dev` — you normally don't set this by hand.
VITE_CONVEX_URL=

# Clerk API keys (https://dashboard.clerk.com → API keys).
CLERK_PUBLISHABLE_KEY=pk_test_...
CLERK_SECRET_KEY=sk_test_...

# NOTE: CLERK_JWT_ISSUER_DOMAIN is NOT set here.
# convex/auth.config.ts reads it from the Convex deployment's environment,
# so set it in the Convex dashboard (Settings → Environment Variables) as the
# Issuer URL of your `convex` JWT template, e.g. https://your-app.clerk.accounts.dev
